# ForcaNieve - Environment Variables
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to the repository

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AEMET OpenData (register at https://opendata.aemet.es)
AEMET_API_KEY=your_aemet_api_key_here

# Groq API (free tier — https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Resend Email (register at https://resend.com)
RESEND_API_KEY=your_resend_api_key_here

# Mapbox (register at https://mapbox.com) — public token, restricted to your domain
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token_here

# Cron Secret — generate with: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here

# App URL (for email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
